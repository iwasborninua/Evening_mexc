# =========================
# APP
# =========================
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Europe/Kyiv

# =========================
# LOGGING
# =========================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# =========================
# TELEGRAM
# =========================
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_NAME=telegram_session

# ID группы / канала
TG_CHAT_ID=

# ID топиков форума
TOPIC_LOW_CAP_ID=
TOPIC_MID_HIGH_CAP_ID=

# =========================
# MEXC API
# =========================
MEXC_API_KEY=
MEXC_API_SECRET=

# Базовый URL API
MEXC_BASE_URL=https://api.mexc.com

# =========================
# TRADING
# =========================
TRADING_ENABLED=false
TRADING_CATEGORY=linear
TRADING_SETTLE_COIN=USDT

# Маржа на 1 ордер в USDT
TRADING_MARGIN=2

# Сколько лимитных ордеров ставить по сигналу
TRADING_ENTRY_ORDERS=2

# Использовать плечо из сигнала
USE_SIGNAL_LEVERAGE=true

# Если нужно принудительное плечо
DEFAULT_LEVERAGE=5

# Максимально допустимое плечо
MAX_LEVERAGE=10

# Разрешить только эти направления: long / short / both
ALLOWED_DIRECTIONS=both

# =========================
# RISK
# =========================
USE_STOP_LOSS=true
USE_TAKE_PROFIT=true
MOVE_SL_TO_BREAKEVEN=true

# Частичное закрытие после TP
PARTIAL_CLOSE_ENABLED=true
PARTIAL_CLOSE_PERCENT=30

# =========================
# FILTERS
# =========================
ALLOW_LOW_CAP=true
ALLOW_MID_HIGH_CAP=true

# Черный список монет через запятую
SYMBOL_BLACKLIST=

# Белый список монет через запятую
SYMBOL_WHITELIST=

# =========================
# DEBUG
# =========================
PRINT_NEW_MESSAGES=true
SAVE_RAW_MESSAGES=false
RAW_MESSAGES_LOG=logs/raw_messages.log